<!DOCTYPE html>
<html lang="hu">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>naphíre.ro – Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@75..100,400..900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#151a21; --ink-soft:#4a5361; --ink-faint:#8b93a1;
  --paper:#ffffff; --paper-warm:#f6f5f2; --line:#e2ddd0;
  --nap:#f2a007; --parazs:#d43d17; --ej:#101722; --erdely:#1d7a4f;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',sans-serif;background:var(--paper-warm);color:var(--ink);font-size:14.5px;line-height:1.5}
a{color:inherit}

header{background:var(--ej);color:#fff;border-bottom:3px solid var(--parazs)}
.header-in{max-width:980px;margin:0 auto;padding:18px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.logo{font-family:'Archivo',sans-serif;font-weight:900;font-size:22px;letter-spacing:-.02em}
.logo .nap{color:#fff}.logo .hire{color:var(--parazs)}.logo .ro{color:#8a93a3}
.admin-cimke{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;color:#aab2c0;text-transform:uppercase}

main{max-width:980px;margin:0 auto;padding:28px 24px 80px}

.info-sav{
  background:#fdf3e7;border:1px solid #f0d9b8;color:#7a5518;
  padding:14px 18px;font-size:13px;line-height:1.6;margin-bottom:28px;
}
.info-sav strong{display:block;margin-bottom:4px;font-size:13.5px}

.panel{background:#fff;border:1px solid var(--line);margin-bottom:22px}
.panel-fej{
  background:var(--ink);color:#fff;padding:12px 20px;
  font-family:'Archivo',sans-serif;font-weight:800;font-size:13px;
  letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:center;gap:10px;
}
.panel-fej .jelzo{width:9px;height:9px;background:var(--nap);flex-shrink:0}
.panel-test{padding:20px}

label{display:block;font-size:12px;font-weight:700;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px}
.mezo{margin-bottom:16px}
.mezo:last-child{margin-bottom:0}
input[type=text], input[type=url], textarea{
  width:100%;font-family:'Inter',sans-serif;font-size:14px;padding:10px 12px;
  border:1px solid var(--line);border-radius:3px;background:var(--paper-warm);
  transition:border-color .15s;
}
input[type=text]:focus, input[type=url]:focus, textarea:focus{outline:none;border-color:var(--parazs);background:#fff}
textarea{resize:vertical;min-height:70px}
.sor2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.sor3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.jegyzet{font-size:12px;color:var(--ink-faint);margin-top:5px}

.kapcsolo-sor{display:flex;align-items:center;gap:10px;margin-bottom:16px}
.kapcsolo-sor input{width:auto}
.kapcsolo-sor span{font-weight:700;font-size:13.5px}

.elonezet{
  border:1px dashed var(--line);background:var(--paper-warm);padding:14px;
  display:flex;gap:12px;align-items:center;margin-top:12px;font-size:12.5px;color:var(--ink-faint);
}
.elonezet img{width:80px;height:56px;object-fit:cover;background:#e2ddd0;flex-shrink:0}

.forras-racs{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.forras-sor{
  display:flex;align-items:center;gap:10px;padding:9px 12px;
  border:1px solid var(--line);border-radius:3px;background:var(--paper-warm);
}
.forras-sor input{width:auto}
.forras-pötty{width:20px;height:20px;border-radius:50%;flex-shrink:0}
.forras-sor .nev{font-weight:700;flex:1}
.forras-sor .regio{font-size:10.5px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.05em;font-weight:700}

.gombsor{display:flex;gap:12px;flex-wrap:wrap;margin-top:8px}
button{
  font-family:'Archivo',sans-serif;font-weight:800;font-size:13px;letter-spacing:.04em;
  text-transform:uppercase;padding:13px 24px;border:none;border-radius:3px;cursor:pointer;
  transition:all .15s;
}
.gomb-fo{background:var(--parazs);color:#fff}
.gomb-fo:hover{background:#b73310}
.gomb-mas{background:#fff;border:1px solid var(--line)!important;color:var(--ink)}
.gomb-mas:hover{border-color:var(--ink)!important}
input[type=file]{display:none}

.allapot{
  display:none;align-items:center;gap:8px;font-size:13px;font-weight:700;color:var(--erdely);
  padding:11px 16px;background:#eaf6ef;border:1px solid #cbe8d6;margin-top:16px;
}
.allapot.mutat{display:flex}

.json-doboz{
  background:var(--ej);color:#c8cdd6;font-family:'JetBrains Mono',monospace;font-size:11.5px;
  padding:16px;border-radius:3px;max-height:260px;overflow:auto;white-space:pre-wrap;word-break:break-all;
  margin-top:14px;line-height:1.6;
}
</style>
</head>
<body>

<header>
  <div class="header-in">
    <span class="logo"><span class="nap">nap</span><span class="hire">híre</span><span class="ro">.ro</span></span>
    <span class="admin-cimke">Szerkesztőségi admin</span>
  </div>
</header>

<main>
  <div class="info-sav">
    <strong>Így működik ez az admin felület</strong>
    A naphíre.ro egy statikus fájl, nincs mögötte adatbázis vagy szerver. Ezért az itt beállított
    dolgok (bannerek, kiemelt téma, kikapcsolt források) egy <code>settings.json</code> nevű
    fájlba kerülnek. Állítsd be lent, amit szeretnél, töltsd le a <strong>settings.json</strong>-t,
    majd FTP-vel/tárhelykezelőn töltsd fel <em>ugyanabba a mappába</em>, ahol a <code>naphire.html</code>
    van (felülírva a régit, ha már létezik). A honlap ezt a fájlt olvassa be induláskor és 5 percenként –
    innentől MINDEN látogatónál érvényes lesz, nem csak a te böngésződben.
    Ha már van korábbi settings.json-od, először töltsd be a "Meglévő settings.json betöltése" gombbal, hogy tovább szerkeszthesd.
  </div>

  <div class="gombsor" style="margin-bottom:26px">
    <button class="gomb-mas" onclick="document.getElementById('betolt-fajl').click()">📂 Meglévő settings.json betöltése</button>
    <input type="file" id="betolt-fajl" accept="application/json">
  </div>

  <!-- SZLOGEN -->
  <div class="panel">
    <div class="panel-fej"><span class="jelzo"></span>Alapadatok</div>
    <div class="panel-test">
      <div class="mezo">
        <label>Szlogen (a logó alatt)</label>
        <input type="text" id="f-szlogen" value="Erdélyi és magyarországi hírek">
      </div>
    </div>
  </div>

  <!-- NAP TÉMÁJA -->
  <div class="panel">
    <div class="panel-fej"><span class="jelzo"></span>A nap témája – kézi kiemelés</div>
    <div class="panel-test">
      <div class="kapcsolo-sor">
        <input type="checkbox" id="t-aktiv" onchange="temaMezokFrissit()">
        <span>Kézzel kiválasztott téma legyen a főoldalon (nem az automatikus felismerés)</span>
      </div>
      <div id="tema-mezok" style="opacity:.4;pointer-events:none">
        <div class="mezo">
          <label>Cím</label>
          <input type="text" id="t-cim" placeholder="pl. Elfogadták a jövő évi költségvetést">
        </div>
        <div class="mezo">
          <label>Rövid lead / összefoglaló</label>
          <textarea id="t-lead" placeholder="2-3 mondatos összefoglaló, ez jelenik meg a téma sávjában"></textarea>
        </div>
        <div class="sor3">
          <div class="mezo">
            <label>Kép URL</label>
            <input type="url" id="t-kep" placeholder="https://...">
          </div>
          <div class="mezo">
            <label>Cikk linkje</label>
            <input type="url" id="t-link" placeholder="https://...">
          </div>
          <div class="mezo">
            <label>Forrás neve</label>
            <input type="text" id="t-forras" placeholder="pl. Maszol">
          </div>
        </div>
        <div class="jegyzet">A rendszer automatikusan megkeresi majd, mely más portálok írtak még hasonló címmel a témáról, és azokat is megjeleníti az „Így írták meg mások" listában.</div>
      </div>
    </div>
  </div>

  <!-- BANNEREK -->
  <div class="panel">
    <div class="panel-fej"><span class="jelzo"></span>Hirdetési helyek</div>
    <div class="panel-test">
      <label style="margin-bottom:10px">Fejléc-banner (a logó mellett, a fejléc sorában – üresen semmi sem jelenik meg)</label>
      <div class="sor2">
        <div class="mezo"><input type="url" id="b0-kep" placeholder="Kép URL (https://... vagy fájlnév, pl. banner.gif)" oninput="bannerElonezetFrissit('b0')"></div>
        <div class="mezo"><input type="url" id="b0-link" placeholder="Kattintáskor megnyíló link"></div>
      </div>
      <div class="elonezet" id="b0-elonezet"><img id="b0-img" src="" alt="" onerror="this.style.opacity=0">Nincs beállítva kép – ez a hely üresen marad a honlapon, nem lóg ki jelölőhely.</div>

      <div style="height:22px"></div>
      <label style="margin-bottom:10px">Tartalmi banner (728×90, a mozaik alatt)</label>
      <div class="sor2">
        <div class="mezo"><input type="url" id="b1-kep" placeholder="Kép URL (https://...)" oninput="bannerElonezetFrissit('b1')"></div>
        <div class="mezo"><input type="url" id="b1-link" placeholder="Kattintáskor megnyíló link"></div>
      </div>
      <div class="elonezet" id="b1-elonezet"><img id="b1-img" src="" alt="" onerror="this.style.opacity=0">Nincs beállítva kép – üresen a szaggatott keretes jelölőhely látszik a honlapon.</div>

      <div style="height:22px"></div>
      <label style="margin-bottom:10px">Oldalsávos banner (300×250, a Legfrissebb lista alatt)</label>
      <div class="sor2">
        <div class="mezo"><input type="url" id="b2-kep" placeholder="Kép URL (https://...)" oninput="bannerElonezetFrissit('b2')"></div>
        <div class="mezo"><input type="url" id="b2-link" placeholder="Kattintáskor megnyíló link"></div>
      </div>
      <div class="elonezet" id="b2-elonezet"><img id="b2-img" src="" alt="" onerror="this.style.opacity=0">Nincs beállítva kép – üresen a szaggatott keretes jelölőhely látszik a honlapon.</div>
    </div>
  </div>

  <!-- FORRÁSOK -->
  <div class="panel">
    <div class="panel-fej"><span class="jelzo"></span>Források be- / kikapcsolása</div>
    <div class="panel-test">
      <div class="jegyzet" style="margin-bottom:14px">A kipipált források hírei NEM jelennek meg a honlapon (se a rovatokban, se a Forrásaink sávban), amíg vissza nem kapcsolod.</div>
      <div class="forras-racs" id="forras-lista"></div>
    </div>
  </div>

  <div class="gombsor">
    <button class="gomb-fo" onclick="letoltSettings()">⬇ settings.json letöltése</button>
    <button class="gomb-mas" onclick="jsonElonezetMutat()">👁 JSON előnézet</button>
  </div>
  <div class="allapot" id="allapot-uzenet">✓ settings.json letöltve – most töltsd fel a szerverre a naphire.html mellé.</div>
  <div class="json-doboz" id="json-doboz" style="display:none"></div>
</main>

<script>
/* A naphire.html-lel megegyező forráslista – ha ott bővíted, itt is vezesd át */
const FORRASOK = [
  { nev:'Maszol', region:'erdely', szin:'#1e9be0' },
  { nev:'Krónika', region:'erdely', szin:'#f2a007' },
  { nev:'Székelyhon', region:'erdely', szin:'#2f7fd6' },
  { nev:'Transtelex', region:'erdely', szin:'#e0315f' },
  { nev:'3Szék', region:'erdely', szin:'#1f8fd1' },
  { nev:'Hargita Népe', region:'erdely', szin:'#2f7fd6' },
  { nev:'Telex', region:'magyar', szin:'#0b7261' },
  { nev:'HVG', region:'magyar', szin:'#d43d17' },
  { nev:'24.hu', region:'magyar', szin:'#1e56c8' },
  { nev:'Index', region:'magyar', szin:'#e8b207' },
  { nev:'444', region:'magyar', szin:'#111111' },
  { nev:'Origo', region:'magyar', szin:'#e07a1f' },
];

document.getElementById('forras-lista').innerHTML = FORRASOK.map(f => `
  <label class="forras-sor">
    <input type="checkbox" data-forras="${f.nev}">
    <span class="forras-pötty" style="background:${f.szin}"></span>
    <span class="nev">${f.nev}</span>
    <span class="regio">${f.region === 'erdely' ? 'Erdély' : 'Magyarország'}</span>
  </label>`).join('');

function temaMezokFrissit(){
  const be = document.getElementById('t-aktiv').checked;
  const doboz = document.getElementById('tema-mezok');
  doboz.style.opacity = be ? '1' : '.4';
  doboz.style.pointerEvents = be ? 'auto' : 'none';
}

function bannerElonezetFrissit(elotag){
  const url = document.getElementById(elotag + '-kep').value.trim();
  const img = document.getElementById(elotag + '-img');
  const doboz = document.getElementById(elotag + '-elonezet');
  if (url){ img.src = url; img.style.opacity = 1; doboz.lastChild.textContent = 'Előnézet a megadott képről:'; }
  else { img.src=''; doboz.lastChild.textContent = elotag === 'b0' ? 'Nincs beállítva kép – ez a hely üresen marad a honlapon, nem lóg ki jelölőhely.' : 'Nincs beállítva kép – üresen a szaggatott keretes jelölőhely látszik a honlapon.'; }
}

function beallitasokOsszeallit(){
  const forrasokKi = [...document.querySelectorAll('#forras-lista input:checked')].map(el => el.dataset.forras);
  return {
    tagline: document.getElementById('f-szlogen').value.trim() || 'Erdélyi és magyarországi hírek',
    banners: {
      fejlec: { kep: document.getElementById('b0-kep').value.trim(), link: document.getElementById('b0-link').value.trim() },
      tartalom: { kep: document.getElementById('b1-kep').value.trim(), link: document.getElementById('b1-link').value.trim() },
      oldalsav: { kep: document.getElementById('b2-kep').value.trim(), link: document.getElementById('b2-link').value.trim() }
    },
    kiemeltTema: {
      aktiv: document.getElementById('t-aktiv').checked,
      cim: document.getElementById('t-cim').value.trim(),
      lead: document.getElementById('t-lead').value.trim(),
      kep: document.getElementById('t-kep').value.trim(),
      link: document.getElementById('t-link').value.trim(),
      forras: document.getElementById('t-forras').value.trim()
    },
    forrasokKi
  };
}

function letoltSettings(){
  const adat = beallitasokOsszeallit();
  const blob = new Blob([JSON.stringify(adat, null, 2)], { type:'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'settings.json';
  document.body.appendChild(a); a.click(); a.remove();
  URL.revokeObjectURL(url);
  const uz = document.getElementById('allapot-uzenet');
  uz.classList.add('mutat');
  setTimeout(() => uz.classList.remove('mutat'), 6000);
}

function jsonElonezetMutat(){
  const doboz = document.getElementById('json-doboz');
  doboz.textContent = JSON.stringify(beallitasokOsszeallit(), null, 2);
  doboz.style.display = doboz.style.display === 'none' ? 'block' : 'none';
}

function beallitasokBetolt(adat){
  document.getElementById('f-szlogen').value = adat.tagline || '';
  const b = adat.banners || {};
  document.getElementById('b0-kep').value = (b.fejlec && b.fejlec.kep) || '';
  document.getElementById('b0-link').value = (b.fejlec && b.fejlec.link) || '';
  document.getElementById('b1-kep').value = (b.tartalom && b.tartalom.kep) || '';
  document.getElementById('b1-link').value = (b.tartalom && b.tartalom.link) || '';
  document.getElementById('b2-kep').value = (b.oldalsav && b.oldalsav.kep) || '';
  document.getElementById('b2-link').value = (b.oldalsav && b.oldalsav.link) || '';
  bannerElonezetFrissit('b0'); bannerElonezetFrissit('b1'); bannerElonezetFrissit('b2');
  const t = adat.kiemeltTema || {};
  document.getElementById('t-aktiv').checked = !!t.aktiv;
  document.getElementById('t-cim').value = t.cim || '';
  document.getElementById('t-lead').value = t.lead || '';
  document.getElementById('t-kep').value = t.kep || '';
  document.getElementById('t-link').value = t.link || '';
  document.getElementById('t-forras').value = t.forras || '';
  temaMezokFrissit();
  const ki = new Set(adat.forrasokKi || []);
  document.querySelectorAll('#forras-lista input').forEach(el => el.checked = ki.has(el.dataset.forras));
}

document.getElementById('betolt-fajl').addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;
  const olvaso = new FileReader();
  olvaso.onload = () => {
    try{ beallitasokBetolt(JSON.parse(olvaso.result)); }
    catch(err){ alert('Nem sikerült beolvasni a fájlt – ellenőrizd, hogy érvényes settings.json-e.'); }
  };
  olvaso.readAsText(file);
});
</script>
</body>
</html>
